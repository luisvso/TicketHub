

@model IEnumerable<TicketHub.Contracts.Prioridade.PrioridadeResponseDTO>
@{
    ViewData["Title"] = "Prioridades";
    var total = Model.Count();
}

@if (TempData["Sucesso"] != null)
{
    <div class="alert alert-success alert-dismissible fade show border-0 shadow-sm rounded-3 mb-4" role="alert">
        <div class="d-flex align-items-center">
            <i class="bi bi-check-circle-fill me-2 fs-5"></i>
            <div><strong>Sucesso!</strong> @TempData["Sucesso"]</div>
        </div>
        <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
    </div>
}

@if (TempData["Erro"] != null)
{
    <div class="alert alert-danger alert-dismissible fade show border-0 shadow-sm rounded-3 mb-4" role="alert">
        <div class="d-flex align-items-center">
            <i class="bi bi-x-circle-fill me-2 fs-5"></i>
            <div><strong>Erro!</strong> @TempData["Erro"]</div>
        </div>
        <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
    </div>
}

<div class="container-fluid">
    <div class="d-flex justify-content-end mb-4 pt-3">
        <a asp-action="Create" class="btn fw-bold px-4 py-2 shadow-sm"
           style="background-color: #0d1b2a; color: white; border-radius: 8px;">
            <i class="bi bi-plus-lg me-2"></i> Nova Prioridade
        </a>
    </div>

    <div class="card border-0 shadow-sm rounded-4 overflow-hidden">
        <div class="card-header bg-white py-4 px-4 border-0 d-flex justify-content-between align-items-center">
            <h6 class="mb-0 fw-bold text-dark text-uppercase" style="letter-spacing: 1.2px;">Prioridades Cadastradas</h6>
            <span class="badge bg-dark bg-opacity-10 text-dark rounded-pill px-3">@total registros</span>
        </div>

        <div class="table-responsive">
            <table class="table table-hover align-middle mb-0">
                <thead style="background-color: #fafbfd;">
                    <tr class="text-muted small text-uppercase" style="font-size: 0.7rem;">
                        <th class="ps-4 py-3">Nome</th>
                        <th>Horas Estimadas</th>
                        <th class="text-end pe-4">Ações</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var item in Model)
                    {
                        <tr>
                            <td class="ps-4"><strong>@item.Nome</strong></td>
                            <td class="text-muted">@item.HorasEstimadas h</td>
                            <td class="text-end pe-4">
                                <div class="d-flex justify-content-end gap-2">
                                    <a asp-action="Edit" asp-route-id="@item.Id" class="btn btn-light btn-sm rounded-circle shadow-sm">
                                        <i class="bi bi-pencil text-primary"></i>
                                    </a>
                                    <a asp-action="Delete" asp-route-id="@item.Id" class="btn btn-light btn-sm rounded-circle shadow-sm">
                                        <i class="bi bi-trash text-danger"></i>
                                    </a>
                                </div>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>