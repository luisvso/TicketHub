@model IEnumerable<TicketHub.Contracts.Prioridade.PrioridadeResponseDTO>

@{
    ViewData["Title"] = "Prioridades";
}


<div class="card shadow-sm border-0">
    <div class="card-header bg-white py-3 d-flex justify-content-between align-items-center">

        @* <form asp-action="Search" method="get" class="d-flex gap-2 mb-4">
            <input type="text" name="searchString" value="@ViewData["CurrentFilter"]" 
                class="form-control" placeholder="Buscar por nome...">
            <button type="submit" class="btn btn-primary">Pesquisar</button>
        </form> *@

        <div class="d-flex align-items-center">
            <i class="bi bi-files me-2 text-muted"></i>
            <strong class="text-secondary text-uppercase" style="font-size: 0.85rem;">Prioridades Cadastradas</strong>
        </div>


        <a asp-action="Create" class="btn btn-dark btn-sm rounded-pill px-3">
            <i class="bi bi-plus"></i> Nova Prioridade 
        </a>
    </div>
    <div class="card-body p-0">
        <table class="table table-hover mb-0">
            <thead class="bg-light">
                <tr>
                    <th class="text-muted border-0 ps-4" style="font-size: 0.75rem;">NOME</th>
                    <th class="text-muted border-0" style="font-size: 0.75rem;">HORAS ESTIMADAS</th>
                    <th class="text-muted border-0 text-center" style="font-size: 0.75rem;">AÇÕES</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var item in Model)
                {
                    <tr>
                        <td class="ps-4 align-middle"><strong>@item.Nome</strong></td>
                        <td class="text-muted align-middle">@item.HorasEstimadas h</td>
                        <td class="text-center align-middle text-muted">
                            <a asp-action="Edit" asp-route-id="@item.Id" class="text-muted me-2"><i class="bi bi-pencil"></i></a>
                            <a asp-action="Delete" asp-route-id="@item.Id" class="text-muted"><i class="bi bi-trash"></i></a>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>