@using TicketHub.Contracts.Chamado
@using TicketHub.Models.Entities
@using TicketHub.Models.Enums
@model IEnumerable<ChamadoResponseDTO>

@{
    ViewData["Title"] = "Dashboard de Chamados";


    var chamados = Model;

    var total = chamados.Count();
    var emAtendimento = chamados.Count(c => c.Status == ChamadoStatus.EmAtendimento);
    var finalizados = chamados.Count(c => c.Status == ChamadoStatus.Finalizado);

    var atrasados = chamados.Count(c => c.Status == ChamadoStatus.EmAtendimento && c.TempoTotalAtendimento.TotalMinutes > 1);
}

<div class="container-fluid">
    <div class="row mb-4 pt-2">

        <div class="d-flex justify-content-end mb-4 pt-3">
            <a asp-action="Create" class="btn fw-bold px-4 py-2 shadow-sm" 
            style="background-color: #0d1b2a; color: white; border-radius: 8px;">
                <i class="bi bi-plus-lg me-2"></i> Novo Chamado
            </a>
        </div>

        <div class="col-md-3">
            <div class="card border-0 shadow-sm border-start border-primary border-4 py-2">
                <div class="card-body d-flex align-items-center">
                    <div class="bg-primary bg-opacity-10 p-3 rounded-3 me-3 text-primary">
                        <i class="bi bi-collection fs-4"></i>
                    </div>
                    <div>
                        <small class="text-muted d-block fw-medium">Total</small>
                        <h4 class="mb-0 fw-bold">@total</h4>
                    </div>
                </div>
            </div>
        </div>

        <div class="col-md-3">
            <div class="card border-0 shadow-sm border-start border-warning border-4 py-2">
                <div class="card-body d-flex align-items-center">
                    <div class="bg-warning bg-opacity-10 p-3 rounded-3 me-3 text-warning">
                        <i class="bi bi-hourglass-split fs-4"></i>
                    </div>
                    <div>
                        <small class="text-muted d-block fw-medium">Em Atendimento</small>
                        <h4 class="mb-0 fw-bold">@emAtendimento</h4>
                    </div>
                </div>
            </div>
        </div>

        <div class="col-md-3">
            <div class="card border-0 shadow-sm border-start border-danger border-4 py-2">
                <div class="card-body d-flex align-items-center">
                    <div class="bg-danger bg-opacity-10 p-3 rounded-3 me-3 text-danger">
                        <i class="bi bi-clock-history fs-4"></i>
                    </div>
                    <div>
                        <small class="text-muted d-block fw-medium">Atrasados</small>
                        <h4 class="mb-0 fw-bold">@atrasados</h4>
                    </div>
                </div>
            </div>
        </div>

        <div class="col-md-3">
            <div class="card border-0 shadow-sm border-start border-success border-4 py-2">
                <div class="card-body d-flex align-items-center">
                    <div class="bg-success bg-opacity-10 p-3 rounded-3 me-3 text-success">
                        <i class="bi bi-check-all fs-4"></i>
                    </div>
                    <div>
                        <small class="text-muted d-block fw-medium">Finalizados</small>
                        <h4 class="mb-0 fw-bold">@finalizados</h4>
                    </div>
                </div>
            </div>
        </div>

    </div>

    @if (TempData["Sucesso"] != null)
    {
        <div class="alert alert-success alert-dismissible fade show border-0 shadow-sm rounded-3 mb-4" role="alert">
            <div class="d-flex align-items-center">
                <i class="bi bi-check-circle-fill me-2 fs-5"></i>
                <div>
                    <strong>Sucesso!</strong> @TempData["Sucesso"]
                </div>
            </div>
            <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
        </div>
    }

    <div class="card border-0 shadow-sm mb-4 rounded-3">
        <div class="card-body p-3">
            <form asp-action="Index" method="get" class="row g-2 align-items-end">
                
                <div class="col-md-3">
                    <label class="form-label small fw-bold text-secondary text-uppercase" style="font-size: 0.65rem;">Setor</label>
                    <select name="setorId" asp-items="ViewBag.Setores" class="form-select form-select-sm border-0 bg-light">
                        <option value="">Todos os Setores</option>
                    </select>
                </div>

                <div class="col-md-3">
                    <label class="form-label small fw-bold text-secondary text-uppercase" style="font-size: 0.65rem;">Prioridade</label>
                    <select name="prioridadeId" asp-items="ViewBag.Prioridades" class="form-select form-select-sm border-0 bg-light">
                        <option value="">Todas as Prioridades</option>
                    </select>
                </div>

                <div class="col-md-3">
                    <label class="form-label small fw-bold text-secondary text-uppercase" style="font-size: 0.65rem;">Status</label>
                    <select name="status" class="form-select form-select-sm border-0 bg-light">
                        <option value="">Todos os Status</option>
                        <option value="Aberto">Aberto</option>
                        <option value="EmAtendimento">Em Atendimento</option>
                        <option value="Finalizado">Finalizado</option>
                        <option value="Cancelado">Cancelado</option>
                    </select>
                </div>

                <div class="col-md-3 d-flex gap-2">
                    <button type="submit" class="btn btn-primary btn-sm w-100 fw-bold shadow-sm">
                        <i class="bi bi-search me-1"></i> Filtrar
                    </button>
                    <a asp-action="Index" class="btn btn-outline-secondary btn-sm" title="Limpar Filtros">
                        <i class="bi bi-arrow-clockwise"></i>
                    </a>
                </div>

            </form>
        </div>
    </div>

    <div class="card border-0 shadow-sm rounded-4 overflow-hidden">
        <div class="card-header bg-white py-4 px-4 border-0 d-flex justify-content-between align-items-center">
            <h6 class="mb-0 fw-bold text-dark text-uppercase" style="letter-spacing: 1.2px;">Lista de Chamados</h6>
            <span class="badge bg-dark bg-opacity-10 text-dark rounded-pill px-3">@total registros</span>
        </div>

        <div class="table-responsive">
            <table class="table table-hover align-middle mb-0">
                <thead style="background-color: #fafbfd;">
                    <tr class="text-muted small text-uppercase" style="font-size: 0.7rem;">
                        <th class="ps-4 py-3">Descrição / Título</th>
                        <th>Setor</th>
                        <th>Prioridade</th>
                        <th>Status</th>
                        <th>Horas de Atendimento</th>
                        <th class="text-end pe-4">Ações</th>
                    </tr>
                </thead>
                <tbody>
                    @if (Model != null && Model.Any()){
                        @foreach (var item in Model){
                            var emAtraso = item.Status == ChamadoStatus.EmAtendimento && item.TempoTotalAtendimento.TotalMinutes > 1;

                            <tr class="@(emAtraso ?  "table-danger" : "")">
                                <td class="ps-4">
                                    <span class="fw-semibold text-dark d-block">@item.Titulo</span>
                                    <small class="text-muted">@item.Descricao</small>
                                </td>
                                <td>
                                    <span class="text-muted small">@item.SetorNome</span>
                                </td>

                                <td>
                                    @{
                                        var pNome = item.PrioridadeNome?.ToLower() ?? "";
                                        var pClass = pNome switch {
                                            "crítica" => "danger",
                                            "alta" => "warning",
                                            "média" => "primary",
                                            _ => "secondary"
                                        };
                                    }
                                    <span class="badge bg-@pClass bg-opacity-10 text-@pClass rounded-pill px-3 py-2 fw-semibold">@item.PrioridadeNome</span>
                                </td>

                                <td>
                                    @if(item.Status == ChamadoStatus.Finalizado){
                                        <span class="badge bg-success ">Concluído</span>
                                    }else if(emAtraso){
                                        <span class="badge bg-danger ">Atrasado</span>
                                    }else if (item.Status == ChamadoStatus.EmAtendimento){
                                        <span class="badge bg-warning">Em Atendimento</span>
                                    }else{
                                        <span class="badge bg-secondary">@item.Status</span>
                                    }
                                </td>

                                <td>
                                    <div class="d-flex align-items-center">
                                        <i class="bi bi-clock me-2 text-muted"></i>
                                        <span class="fw-medium @( emAtraso ? "text-danger" : "text-dark")">
                                            @($"{ (int)item.TempoTotalAtendimento.TotalHours }h { item.TempoTotalAtendimento.Minutes }min")
                                        </span>
                                    </div>
                                </td>
                                <td class="text-end pe-4">
                                    <div class="d-flex justify-content-end align-items-center gap-2">
                                        
                                        @if (item.Status == ChamadoStatus.Aberto)
                                        {
                                            <form asp-action="CheckIn" asp-route-id="@item.Id" method="post">
                                                <button type="submit" class="btn btn-sm btn-outline-success fw-bold px-3 rounded-pill">
                                                    <i class="bi bi-play-fill"></i> Iniciar
                                                </button>
                                            </form>
                                        }
                                        else if (item.Status == ChamadoStatus.EmAtendimento)
                                        {
                                            <a asp-action="CheckOut" asp-route-id="@item.Id" class="btn btn-sm btn-success fw-bold px-3 rounded-pill shadow-sm">
                                                <i class="bi bi-check2-circle"></i> Finalizar
                                            </a>
                                        }

                                        <div class="dropdown">
                                            <button class="btn btn-light btn-sm rounded-circle shadow-sm" type="button" data-bs-toggle="dropdown" aria-expanded="false">
                                                <i class="bi bi-three-dots-vertical"></i>
                                            </button>
                                            <ul class="dropdown-menu dropdown-menu-end shadow border-0">
                                                <li><h6 class="dropdown-header">Gerenciar</h6></li>
                                                
                                                @if(item.Status == ChamadoStatus.Aberto) {
                                                    <li>
                                                        <a class="dropdown-item d-flex align-items-center" asp-action="Edit" asp-route-id="@item.Id">
                                                            <i class="bi bi-pencil me-2 text-primary"></i> Editar
                                                        </a>
                                                    </li>
                                                }

                                                @if(item.Status != ChamadoStatus.Finalizado && item.Status != ChamadoStatus.Cancelado) {
                                                    <li>
                                                        <form asp-action="Cancelar" asp-route-id="@item.Id" method="post" onsubmit="return confirm('Deseja realmente cancelar?')">
                                                            <button type="submit" class="dropdown-item d-flex align-items-center text-warning">
                                                                <i class="bi bi-x-circle me-2"></i> Cancelar
                                                            </button>
                                                        </form>
                                                    </li>
                                                }

                                                <li><hr class="dropdown-divider"></li>
                                                <li>
                                                    <form asp-action="Delete" asp-route-id="@item.Id" method="post">
                                                        <button type="submit" class="dropdown-item d-flex align-items-center text-danger">
                                                            <i class="bi bi-trash me-2"></i> Excluir
                                                        </button>
                                                    </form>
                                                </li>
                                            </ul>
                                        </div>

                                    </div>
                                </td>

                            </tr>
                        }
                    }else{
                        <tr>
                            <td colspan="6" class="text-center py-5 text-muted">
                                <i class="bi bi-inbox fs-2 d-block mb-2">Nenhum Chamado registrado foi encontrado</i>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>